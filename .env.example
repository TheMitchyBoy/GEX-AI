DATABASE_URL=postgresql://user:pass@host:5432/railway
DEFAULT_TICKER=SPX
SUPPORTED_TICKERS=SPX,SPY,NDX
LOOKBACK_DAYS=90
FORECAST_POLL_SEC=60
PROCESSOR_HEALTH_URL=
API_HOST=0.0.0.0
API_PORT=8000
WRITE_PREDICTIONS=0
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.35
LLM_PREDICTION_SOURCE=gex-ai-llm
LLM_CACHE_ENABLED=1
API_KEY=
